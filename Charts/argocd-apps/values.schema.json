{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "argocd-apps Helm chart",
    "description": "Helm chart for creating app of apps to deploy services",
    "type": "object",
    "properties": {
        "destination": {
            "type": "object",
            "properties": {
                "name": {
                    "description": "\"The name of the destination cluster. e.g. 'i21' 'pollux' 'acastus'\"",
                    "type": "string"
                },
                "namespace": {
                    "description": "\"The namespace in the destination cluster. At DLS this is always the same as the project name\"",
                    "type": "string"
                }
            },
            "additionalProperties": false
        },
        "global": {
            "description": "Global values shared between all subcharts",
            "$comment": "Added automatically by 'helm schema' to allow this chart to be used as a Helm dependency, as the `additionalProperties` setting would otherwise collide with Helm's special 'global' values key.",
            "type": [
                "object",
                "null"
            ]
        },
        "project": {
            "description": "\"The ArgoCD project. At DLS this is the same as the beamline namespace. or 'accelerator'\"",
            "type": "string"
        },
        "services": {
            "type": [
                "object",
                "null"
            ],
            "additionalProperties": {
                "type": [
                    "object",
                    "null"
                ],
                "properties": {
                    "destination": {
                        "type": [
                            "object",
                            "null"
                        ],
                        "properties": {
                            "name": {
                                "default": "",
                                "type": "string"
                            },
                            "namespace": {
                                "default": "",
                                "type": "string"
                            }
                        },
                        "additionalProperties": false
                    },
                    "enabled": {
                        "default": true,
                        "type": "boolean"
                    },
                    "labels": {
                        "default": {},
                        "type": "object",
                        "additionalProperties": {
                            "description": "Custom labels applied to the resource.",
                            "type": "string",
                            "pattern": "^[a-zA-Z0-9](?:(?!--)[a-zA-Z0-9-]){0,62}$",
                            "maxLength": 63
                        }
                    },
                    "removed": {
                        "default": false,
                        "type": "boolean"
                    },
                    "repoURL": {
                        "default": "",
                        "type": "string"
                    },
                    "targetRevision": {
                        "default": "",
                        "type": "string"
                    },
                    "values": {
                        "type": "object",
                        "additionalProperties": false
                    }
                },
                "additionalProperties": false
            }
        },
        "source": {
            "type": "object",
            "properties": {
                "repoURL": {
                    "description": "\"The URL of the Git repository containing the application manifests.\"",
                    "type": "string"
                },
                "targetRevision": {
                    "description": "\"The target revision (branch, tag, commit) of the Git repository.\"",
                    "type": "string"
                }
            },
            "additionalProperties": false
        }
    },
    "additionalProperties": false
}
